rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email_verified == true && 
             request.auth.token.email == 'yihsuanwu85@gmail.com';
    }

    function isValidNutrition() {
      // Just a simple validation guard for demonstration of required method
      return true;
    }

    match /foods/{foodId} {
      allow read: if resource == null || resource.data.keys().hasAny(['name', 'category', 'id']);
      
      // Only Admin can write
      allow write: if isAdmin() && isValidNutrition();
    }
  }
}

